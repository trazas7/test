
SELECT 
    rrp.page_code,
    CASE 
        WHEN ptav.attribute_value = 'Credit' AND debt_tag.tag_value = 'Y' THEN
            CASE 
                WHEN lower(lang_tag.tag_value) = 'english' OR lang_tag.tag_value IS NULL THEN 4
                WHEN lower(lang_tag.tag_value) = 'chinese' THEN 2
                WHEN lower(lang_tag.tag_value) = 'japanese' THEN 3
                WHEN lower(lang_tag.tag_value) = 'french' THEN 12
                ELSE NULL
            END
        WHEN ptav.attribute_value = 'Credit' AND (debt_tag.tag_value IS NULL OR debt_tag.tag_value = 'N') THEN
            CASE 
                WHEN lower(lang_tag.tag_value) = 'english' OR lang_tag.tag_value IS NULL THEN 1
                WHEN lower(lang_tag.tag_value) = 'chinese' THEN 2
                WHEN lower(lang_tag.tag_value) = 'japanese' THEN 3
                WHEN lower(lang_tag.tag_value) = 'french' THEN 12
                ELSE NULL
            END
        WHEN ptav.attribute_value = 'Market360' THEN
            CASE 
                WHEN lower(lang_tag.tag_value) = 'english' OR lang_tag.tag_value IS NULL THEN 1
                WHEN lower(lang_tag.tag_value) = 'chinese' THEN 2
                WHEN lower(lang_tag.tag_value) = 'japanese' THEN 3
                WHEN lower(lang_tag.tag_value) = 'french' THEN 12
                ELSE NULL
            END
        ELSE NULL
    END AS bbg_class
FROM 
    fidataadm.rixml_receiver_page rrp
INNER JOIN fidataadm.pub_type_attribute_value ptav ON ptav.id = rrp.publication_type_category_id
INNER JOIN fidataadm.publication_type_attribute pta ON pta.pubtype_attr_val_id = ptav.id
INNER JOIN fidataadm.publication_type pt ON pt.id = pta.publication_type_id
INNER JOIN fidataadm.publication pub ON pub.publication_type_id = pt.id
LEFT JOIN fidataadm.publication_has_tag_value lang_tag 
    ON lang_tag.publication_id = pub.id 
    AND EXISTS (
        SELECT 1 
        FROM fidataadm.tag_type tt 
        WHERE tt.id = lang_tag.tag_type_id 
        AND tt.name = 'Language'
    )
LEFT JOIN fidataadm.publication_has_tag_value debt_tag 
    ON debt_tag.publication_id = pub.id 
    AND EXISTS (
        SELECT 1 
        FROM fidataadm.tag_type tt 
        WHERE tt.id = debt_tag.tag_type_id 
        AND tt.name = 'US_Debt'
    )
WHERE 
    pub.id = '377933';
