slide.shapes.load("items");
await context.sync();

for (const shape of slide.shapes.items) {
  if (shape.textFrame) {
    shape.textFrame.load("text");
  }
}
await context.sync();

for (const shape of slide.shapes.items) {
  if (shape.textFrame?.text) {
    fullText += shape.textFrame.text + "\n";
  }
}
