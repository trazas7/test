SELECT
    ptav.attribute_value AS publication_type,
    coalesce(lower(ph_language.tag_value), 'english') AS language,
    coalesce(lower(ph_asset_class.tag_value), 'default_asset_class') AS asset_class,
    CASE
        WHEN EXISTS (
            SELECT 1
            FROM fidataadm.publication_has_tag_value ph_us_debt
            INNER JOIN fidataadm.tag_type tt_us_debt ON tt_us_debt.id = ph_us_debt.tag_type_id
            WHERE ph_us_debt.publication_id = pub.id AND tt_us_debt.name = 'US_Debt'
        ) THEN 'Y' ELSE 'N'
    END AS is_us_debt
FROM
    fidataadm.publication pub
INNER JOIN fidataadm.publication_type pt ON pub.publication_type_id = pt.id
INNER JOIN fidataadm.publication_type_attribute pta ON pta.publication_type_id = pt.id
INNER JOIN fidataadm.publication_type_attribute_value ptav ON ptav.id = pta.pubtype_attr_val_id AND ptav.attribute_name = 'pub_type_category'
LEFT JOIN fidataadm.publication_has_tag_value ph_language ON ph_language.publication_id = pub.id
INNER JOIN fidataadm.tag_type tt_language ON tt_language.id = ph_language.tag_type_id AND tt_language.column_name = 'bnpp_language'
LEFT JOIN fidataadm.publication_has_tag_value ph_asset_class ON ph_asset_class.publication_id = pub.id
INNER JOIN fidataadm.tag_type tt_asset_class ON tt_asset_class.id = ph_asset_class.tag_type_id AND tt_asset_class.column_name = 'bnpp_asset_class'
WHERE
    pub.id = 378023;
