
private static QueryBuilder filterQuery(Set<String> tags, String... fields) {
    BoolQueryBuilder queryBuilder = boolQuery();

    for (String field : fields) {
        // Add inclusion logic for all tags
        tags.forEach(tag -> queryBuilder.should(termQuery(field + ".keyword", tag))); // Include matching tags
    }

    // Add dynamic exclusion logic for cases where only one asset class exists from the tags set
    tags.forEach(tag -> {
        queryBuilder.mustNot(
            QueryBuilders.boolQuery()
                .must(termQuery("bnpp_asset_class.keyword", tag)) // Must contain the tag
                .mustNot(existsQuery("bnpp_asset_class[1]")) // Ensure no additional asset classes
        );
    });

    return queryBuilder;
}
