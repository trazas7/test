<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Disclaimer</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            margin: 20px;
        }
        .btn {
            padding: 10px 20px;
            margin-top: 10px;
            border: none;
            cursor: pointer;
            font-size: 16px;
            background: #007bff;
            color: white;
        }
    </style>
</head>
<body id="pageContent">

    <h1>Disclaimer</h1>
    <p>
        This website provides information for general purposes only. By continuing, you agree that we are not responsible for any decisions made based on this information.
    </p>

    <p>
        Read more details 
        <a href="https://www.example.com" target="_blank" onclick="openNewTab(event)">here</a>.
    </p>

    <!-- Close Button -->
    <button class="btn" onclick="closePage()">Close</button>

    <script>
        // If page is inside an iframe, force it to open in a new tab
        if (window.self !== window.top) {
            window.open(window.location.href, "_blank");
            window.top.location.href = "about:blank";
        }

        // Open links in a new tab to prevent navigation issues
        function openNewTab(event) {
            event.preventDefault();  
            window.open(event.target.href, "_blank");
        }

        // Close the page or go back if blocked
        function closePage() {
            if (window.opener) {
                window.close();
            } else {
                window.history.back(); // Fallback if close is blocked
            }
        }

        // Reload if user navigates back (ensures close button keeps working)
        window.addEventListener("pageshow", function (event) {
            if (event.persisted) {
                location.reload();
            }
        });
    </script>

</body>
</html>
