for (const buttonId in TASK_CONFIG) {
  getElementById(buttonId).addEventListener("click", async () => {
    try {
      let selectedText = "";

      if (Office.context.host === Office.HostType.Word) {
        await Word.run(async (context) => {
          const selection = context.document.getSelection();
          selection.load("text");
          await context.sync();
          selectedText = selection.text.trim();
        });
      } else if (Office.context.host === Office.HostType.PowerPoint) {
        await PowerPoint.run(async (context) => {
          const selection = context.presentation.getSelectedTextRange();
          selection.load("text");
          await context.sync();
          selectedText = selection.text.trim();
        });
      }

      const task = TASK_CONFIG[buttonId];
      const promptText = selectedText
        ? task.prompt + selectedText
        : null;

      if (!promptText) {
        showMessage("Please select text in the document first.", "error");
        return;
      }

      showPromptScreen({
        heading: task.heading,
        prompt: promptText,
        role: task.role,
        mode: task.mode,
      });

    } catch (error) {
      showMessage("Error retrieving selected text from document.", "error");
    }
  });
}
