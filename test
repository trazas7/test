public void downloadSPFileAndPutOnNAS(final String fileName, final String touchHash) {
    if (StringUtils.isBlank(fileName) || StringUtils.isBlank(touchHash)) {
        throw new IllegalArgumentException("fileName and touchHash must not be blank");
    }
    
    log.info("-> downloadSPFileAndPutOnNAS: fileName: {} and hash: {}", fileName, touchHash);
    byte[] fileContent = null;
    int maxRetries = 3;
    int currentRetry = 0;
    
    while (currentRetry < maxRetries) {
        try {
            log.info("Downloading file from SharePoint -> {}", fileName);
            fileContent = getDownloadedSPFileContent(fileName);
            log.info("<- Downloading file from SharePoint {}", fileName);
            break;
        } catch (TimeoutException tex) {
            currentRetry++;
            if (currentRetry == maxRetries) {
                String errorMsg = String.format("Service call timeout after %d retries while downloading file from SharePoint: %s", maxRetries, fileName);
                log.error(errorMsg, tex);
                throw new RuntimeException(errorMsg, tex);
            }
            long waitTime = Math.min(1000L * (long) Math.pow(2, currentRetry), 8000L); // exponential backoff with max 8 seconds
            try {
                Thread.sleep(waitTime);
            } catch (InterruptedException ie) {
                Thread.currentThread().interrupt();
                throw new RuntimeException("Interrupted while waiting to retry download", ie);
            }
            log.info("Retry {} of {} after timeout downloading file {}", currentRetry, maxRetries, fileName);
        } catch (Exception ex) {
            log.error("Error downloading file: {} - {}", fileName, ex.getMessage(), ex);
            throw new RuntimeException("Error downloading file: " + fileName, ex);
        }
    }
    
    if (fileContent == null || fileContent.length == 0) {
        throw new RuntimeException("Downloaded file content is empty for file: " + fileName);
    }
    
    File targetFile = new File(nasUnprocessedFilePath + touchHash);
    try {
        log.info("-> Writing file with size {} to the NAS unprocessed file path {}", 
                fileContent.length, nasUnprocessedFilePath + touchHash);
                
        try (FileOutputStream fos = new FileOutputStream(targetFile)) {
            fos.write(fileContent);
            fos.flush();
        }
        
        log.info("<- Writing file to NAS unprocessed file path");
    } catch (IOException ioe) {
        String errorMsg = String.format("Error creating file %s at NAS drive %s", 
                fileName, nasUnprocessedFilePath + touchHash);
        log.error(errorMsg, ioe);
        throw new RuntimeException(errorMsg, ioe);
    }
    
    log.info("<- downloadSPFileAndPutOnNAS");
}
