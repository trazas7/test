interface AppConfig {
  MARKETS360_BASE_URL: string;
  GMRC_BASE_URL: string;
  SSO_BASE_URL: string;
}

// Declare constants that will be assigned after loading
let MARKETS360_BASE_URL = '';
let GMRC_BASE_URL = '';
let SSO_BASE_URL = '';

// Load the config and set constants
function loadConfig(): Promise<void> {
  return fetch('./config.json')
    .then(response => {
      if (!response.ok) throw new Error("Could not load config.json");
      return response.json();
    })
    .then((config: AppConfig) => {
      MARKETS360_BASE_URL = config.MARKETS360_BASE_URL;
      GMRC_BASE_URL = config.GMRC_BASE_URL;
      SSO_BASE_URL = config.SSO_BASE_URL;
    });
}