
function renderUI(authenticated: boolean) {
  const app = document.getElementById("app");
  if (!app) return;

  if (authenticated) {
    app.innerHTML = `
      <h2>Welcome!</h2>
      <p>You are signed in via SSO.</p>
    `;
  } else {
    app.innerHTML = `
      <button id="ssoLoginBtn">Login with SSO</button>
    `;

    const loginBtn = document.getElementById("ssoLoginBtn");
    loginBtn?.addEventListener("click", openSSOLogin);
  }
}

function openSSOLogin() {
  const popup = window.open(
    "https://markets360-stg.dev.bnpparibas.com", // existing SSO-protected site
    "_blank",
    "width=600,height=700"
  );

  if (!popup) {
    console.error("Popup blocked");
    return;
  }

  const check = setInterval(() => {
    if (popup.closed) {
      clearInterval(check);
      console.log("Popup closed — assuming login is complete");
      // Now show the welcome screen
      renderUI(true);
    }
  }, 500);
}

Office.onReady(() => {
  console.log("Office is ready");

  // Initial state: assume not authenticated
  renderUI(false);
});
