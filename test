
<!DOCTYPE html>
<html>
<head>
  <title>Publisher2 Add-in</title>
  <!-- Load Office.js -->
  <script src="https://appsforoffice.microsoft.com/lib/1/hosted/office.js"></script>
</head>
<body>
  <button id="ssoLoginBtn">Login with SSO</button>
  <!-- Webpack should inject or compile this -->
  <script src="taskpane.js"></script>
</body>
</html>

Office.onReady(() => {
  document.getElementById("ssoLoginBtn")?.addEventListener("click", openSSOLogin);
});

function openSSOLogin() {
  const popup = window.open("https://markets360-stg.dev.bnpparibas.com", "_blank", "width=600,height=700");
  if (!popup) {
    alert("Popup blocked");
    return;
  }

  const check = setInterval(() => {
    if (popup.closed) {
      clearInterval(check);
      alert("Popup closed — assuming login is done");
    }
  }, 500);
}
