
Office.onReady(() => {
  console.log("Office is ready");

  const loginButton = document.getElementById("ssoLoginBtn");
  if (loginButton) {
    loginButton.addEventListener("click", openSSOLogin);
  }

  // Start with not authenticated state
  showAuthState(false);
});

function openSSOLogin() {
  const popup = window.open(
    "https://markets360-stg.dev.bnpparibas.com", // Replace with real SSO-protected page
    "_blank",
    "width=600,height=700"
  );

  if (!popup) {
    console.error("Popup blocked");
    return;
  }

  const checkInterval = setInterval(() => {
    if (popup.closed) {
      clearInterval(checkInterval);
      console.log("Popup closed — assuming login done");
      showAuthState(true);
    }
  }, 500);
}

function showAuthState(isAuthenticated) {
  const unauth = document.getElementById("unauthenticated");
  const auth = document.getElementById("authenticated");

  if (!unauth || !auth) return;

  unauth.style.display = isAuthenticated ? "none" : "block";
  auth.style.display = isAuthenticated ? "block" : "none";
}
