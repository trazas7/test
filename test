this.showTradeIdeasPopup = function(callback) {
    var div = $("<div> If you are opening or closing a new trade idea, please update the M360 Trade tracker. </div>");

    div.dialog({
        title: "Trade Idea Update",
        width: 450,
        draggable: false,
        closeOnEscape: false,
        modal: true,
        resizable: false,
        position: { my: "center", at: "center", of: window },
        open: function(event, ui) {
            $(".ui-dialog-titlebar-close", ui.dialog | ui).hide(); // Hide close button
        },
        buttons: [
            {
                text: "OK",
                click: function () {
                    div.dialog("close");
                    window.open(encodeURI(tradeIdeaHomePageUrl), "_blank"); // Open the trade idea page
                    if (callback) callback(); // Execute the callback after closing the dialog
                }
            }
        ]
    });
};

if (self.publicationTypeName() == 'Trade Ideas') {
    self.showTradeIdeasPopup(function() {
        // This will run only AFTER the popup is closed
        self.msg('Document saved', "success");
        window.location = "/publisher2/publications"; // Redirect user
    });
} else {
    self.msg('Document saved', "success");
    window.location = "/publisher2/publications";
}



