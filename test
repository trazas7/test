def update_token():
    token_url = 'https://api-staging.staging.echonet/oauth2/v1/token'
    headers = {"Content-Type": "application/x-www-form-urlencoded"}
    params = {"grant_type": "client_credentials"}
    
    response = requests.post(token_url, auth=HTTPBasicAuth(client_id, client_secret), headers=headers, params=params, verify=False, proxies=proxies)
    
    if response.status_code == 200:
        return response.json()["access_token"]
    else:
        raise Exception("Failed to obtain token")

def search_articles(headers, days=2):
    end_date = datetime.now()
    start_date = end_date - timedelta(days=days)
    search_params = {
        "startDate": f"now-{days}d/d",
        "endDate": "now/d"
    }

    response = requests.post(search_url, json=search_params, headers=headers, verify=False, proxies=proxies)
    
    if response.status_code == 200:
        return [doc["researchId"] for doc in response.json().get("researchDocuments", [])]
    else:
        raise Exception(f"Search failed. Status code: {response.content}")

def download_and_process_article(pub_id, headers):
    url = f"{base_url}/{pub_id}"
    response = requests.get(url, headers=headers, verify=False, proxies=proxies)

    if response.status_code == 200:
        # Ensure 'data' directory exists
        os.makedirs('data', exist_ok=True)
        print(f"Saving data in folder: 'data'")

        zip_path = f"data/{pub_id}.zip"
        with open(zip_path, "wb") as file:
            file.write(response.content)

        with ZipFile(zip_path, mode="r") as zip_ref:
            zip_ref.extractall("data")

        # Rename the rixml.xml file if it exists
        rixml_path = f"data/{pub_id}_r1xml.xml"
        if os.path.exists(rixml_path):
            new_rixml_path = f"data/{pub_id}_r1xml.xml"
            os.rename(rixml_path, new_rixml_path)

        # Rename the summary.html file if it exists
        summary_path = f"data/summary.html"
        if os.path.exists(summary_path):
            new_summary_path = f"data/{pub_id}_summary.html"
            os.rename(summary_path, new_summary_path)
        
        # Remove the zip file after extraction
        os.remove(zip_path)
        
        # Rename files without an extension to .pdf
        for filename in os.listdir('data'):
            file_path = os.path.join('data', filename)
            if os.path.isfile(file_path) and '.' not in filename:
                new_file_path = f"{file_path}.pdf"
                os.rename(file_path, new_file_path)
                print(f"Renamed {filename} to {new_file_path}")

        print(f"Successfully processed article {pub_id}")
    else:
        print(f"Failed to download and process article {pub_id}. Status code: {response.content}")

def process_articles(pub_ids, headers):
    for pub_id in pub_ids:
        try:
            download_and_process_article(pub_id, headers)
        except Exception as e:
            print(f"Error processing article {pub_id}: {str(e)}")
            if "token" in str(e).lower():
                token = update_token()
                headers = {"Authorization": f"Bearer {token}"}
                try:
                    download_and_process_article(pub_id, headers)
                except Exception as e:
                    print(f"Failed to process article {pub_id} after token refresh: {str(e)}")

def main():
    token = update_token()
    headers = {"Authorization": f"Bearer {token}"}

    choice = input("Enter '1' to search and download, or '2' to provide a list of IDs: ")

    if choice == '1':
        pub_ids = search_articles(headers, days=2)
        process_articles(pub_ids, headers)
    elif choice == '2':
        pub_ids = input("Enter the publication IDs separated by a space: ").split()
        process_articles(pub_ids, headers)
    else:
        print("Invalid choice")

if __name__ == "__main__":
    main()
