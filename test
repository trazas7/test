import org.springframework.cache.annotation.CacheEvict;
import org.springframework.cache.annotation.Cacheable;
import org.springframework.stereotype.Service;

@Service
public class ContactService {

    @Cacheable(value = "contacts", key = "#id")
    public Contact getContactById(String id) {
        // This method will cache its result. Subsequent calls with the same id will return the cached value.
        return fetchContactFromDatabase(id);
    }

    @CacheEvict(value = "contacts", key = "#contact.id")
    public Contact updateContact(Contact contact) {
        // This method will update the contact and remove the old cached value.
        Contact updatedContact = updateContactInDatabase(contact);
        return updatedContact;
    }

    @CacheEvict(value = "contacts", allEntries = true)
    public void clearCache() {
        // This method will clear all entries in the 'contacts' cache.
        System.out.println("Clearing entire contacts cache");
    }

    private Contact fetchContactFromDatabase(String id) {
        // Simulate database access
        System.out.println("Fetching contact from database: " + id);
        try {
            Thread.sleep(1000); // Simulate slow database query
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }
        return new Contact(id, "John Doe", "john@example.com");
    }

    private Contact updateContactInDatabase(Contact contact) {
        // Simulate database update
        System.out.println("Updating contact in database: " + contact.getId());
        try {
            Thread.sleep(500); // Simulate database update
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }
        return contact; // Return the updated contact
    }
}
