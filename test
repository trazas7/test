<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Disclaimer</title>
    <style>
        /* Page Styling */
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            margin: 20px;
        }

        /* Close Button */
        .btn {
            padding: 10px 20px;
            margin-top: 10px;
            border: none;
            cursor: pointer;
            font-size: 16px;
            background: #007bff;
            color: white;
        }
    </style>
</head>
<body>

    <h1>Disclaimer</h1>
    <p>
        This website provides information for general purposes only. By continuing, you agree that we are not responsible for any decisions made based on this information.
    </p>

    <p>Read more details <a href="https://www.example.com" target="_blank">here</a>.</p>

    <!-- Close Button -->
    <button class="btn" onclick="closePage()">Close</button>

    <script>
        function closePage() {
            if (window.opener) {
                // If the page was opened via window.open(), close it
                window.close();
            } else {
                // If opened manually, hide the content instead
                document.body.innerHTML = "<h2>Thank you!</h2>";
            }
        }
    </script>

</body>
</html>
