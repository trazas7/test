getElementById("insert-result").addEventListener("click", async () => {
  const outputDiv = getElementById("output-text");
  let textToInsert = "";

  const selection = window.getSelection();
  if (selection && selection.toString().trim()) {
    textToInsert = selection.toString();
  } else {
    textToInsert = outputDiv.innerText;
  }

  if (!textToInsert.trim()) {
    showMessage("No text to insert.", "error");
    return;
  }

  try {
    if (Office.context.host === Office.HostType.Word) {
      await Word.run(async (context) => {
        context.document.getSelection().insertText(textToInsert, Word.InsertLocation.replace);
        await context.sync();
      });
    } else if (Office.context.host === Office.HostType.PowerPoint) {
      await PowerPoint.run(async (context) => {
        const slide = context.presentation.getSelectedSlide();
        slide.load("shapes");
        await context.sync();

        const shapes = slide.shapes;
        if (shapes.items.length > 0) {
          const shape = shapes.items[0]; // Insert into the first shape
          shape.textFrame.textRange.insertText(textToInsert, PowerPoint.InsertLocation.replace);
          await context.sync();
        } else {
          showMessage("No shape selected to insert text.", "error");
        }
      });
    }
  } catch (error) {
    showMessage("Error inserting text.", "error");
  }
});
