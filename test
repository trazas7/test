import json
import os
import sys
from zipfile import ZipFile

import requests
from requests.auth import HTTPBasicAuth

# Suppress insecure request warnings
# urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

headers = {}
client_id = "WAfmUZHwqyWS1Jjq5AVq14b4i2nBNDX"
client_secret = "HimoDKpw5OiQisrch"
response = ""

# Base URL for the API
base_url = 'https://api-staging.staging.echonet'

def update_request_header_with_new_token():
    global headers
    headers_token = {"Content-Type": "application/x-www-form-urlencoded"}
    params = {"grant_type": "client_credentials"}

    token_response = requests.post(f'{base_url}/oauth2/v1/token',
                                   auth=HTTPBasicAuth(client_id, client_secret),
                                   headers=headers_token, params=params, verify=False)

    bearer_token = json.loads(token_response.content)["access_token"]
    headers = {"Authorization": f"Bearer {bearer_token}"}

if len(sys.argv) < 2:
    print("Please provide publication IDs as a comma-separated list.")
    sys.exit(1)

pub_ids = sys.argv[1].split(',')

# Create data directory if it doesn't exist
if not os.path.exists('data'):
    os.makedirs('data')

for pub_id in pub_ids:
    pub_id = pub_id.strip()
    print(f"Processing publication ID: {pub_id}")
    status = True
    while status:
        # Download zip
        response = requests.get(
            f"{base_url}/gm-gm-research-content-internet/v1/documents/{pub_id}",
            headers=headers, verify=False)
        
        # If request fails, retry with new bearer token
        if response.status_code != 200:
            update_request_header_with_new_token()
        else:
            status = False
            # Save zip
            zip_path = f"data/{pub_id}.zip"
            with open(zip_path, mode="wb") as file:
                file.write(response.content)
            
            # Extract contents of the zip
            with ZipFile(zip_path, 'r') as zObject:
                # Extracting all the members of the zip into the "data" directory
                zObject.extractall(path="data")
            
            # Rename rixml and summary files if they exist
            rixml_path = os.path.join("data", "rixml.xml")
            if os.path.exists(rixml_path):
                os.rename(rixml_path, f"data/{pub_id}_rixml.xml")
            
            summary_path = os.path.join("data", "summary.html")
            if os.path.exists(summary_path):
                os.rename(summary_path, f"data/{pub_id}_summary.html")

print("All publications processed successfully.")
