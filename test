DELETE FROM FIDATAADM.RIXML_RECEIVER_PAGE
WHERE PAGE_CODE = '1'
  AND PAGE_CLASS = 'BNP Paribas Markets 360 and Credit 360 - excl US Debt research (English)'
  AND DISPLAY_NAME = 'BNP Paribas Markets 360 and Credit 360 - excl US Debt research (English)'
  AND RECEIVER_ID = (SELECT ID FROM FIDATAADM.RIXML_RECEIVERS WHERE NAME='BLOOMBERG' AND IS_ACTIVE='Y')
  AND IS_ACTIVE = 'Y'
  AND PUBLICATION_TYPE_CATEGORY_ID = (SELECT ID FROM FIDATAADM.PUBLICATION_TYPE_ATTRIBUTE_VALUE WHERE ATTRIBUTE_NAME='pub_type_category' AND ATTRIBUTE_VALUE='Credit')
  AND PUBLICATION_LANGUAGE = 'English'
  AND IS_US_DEBT = 'N';
