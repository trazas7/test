const disclaimerModal = document.getElementById("disclaimer-modal") as HTMLElement;
const loginScreen = document.getElementById("login-screen") as HTMLElement;
const acceptBtn = document.getElementById("accept-terms-btn") as HTMLButtonElement;

if (localStorage.getItem("termsAccepted") === "true") {
  disclaimerModal.style.display = "none";
  loginScreen.style.display = "block";
} else {
  disclaimerModal.style.display = "flex";
  loginScreen.style.display = "none";
}

acceptBtn.addEventListener("click", () => {
  localStorage.setItem("termsAccepted", "true");
  disclaimerModal.style.display = "none";
  loginScreen.style.display = "block";
});


.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

.modal-content {
  background-color: #fff;
  padding: 20px;
  width: 90%;
  max-width: 350px;
  border-radius: 8px;
  box-shadow: 0 0 10px rgba(0,0,0,0.25);
  text-align: center;
}

.modal-body {
  max-height: 150px;
  overflow-y: auto;
  margin: 15px 0;
  font-size: 14px;
  text-align: left;
}

#accept-terms-btn {
  background-color: #1AA48C;
  color: white;
  padding: 10px 20px;
  font-size: 14px;
  border: none;
  border-radius: 5px;
  cursor: pointer;
}

<!-- DISCLAIMER MODAL -->
<div id="disclaimer-modal" class="modal-overlay" style="display: none;">
  <div class="modal-content">
    <h2>Terms & Conditions</h2>
    <div class="modal-body">
      <p>
        By using this add-in, you agree to the terms of use. This tool processes content temporarily to deliver its functionality. No data is stored permanently.
      </p>
    </div>
    <button id="accept-terms-btn">I Accept</button>
  </div>
</div>
