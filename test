import java.util.List;
import java.util.Set;
import java.util.stream.Collectors;

public class Main {
    public static boolean checkTopics(List<String> topicIds, List<TopicDto> topicDtoList) {
        // Convert topicIds to a set for fast lookup
        Set<String> topicIdSet = topicIds.stream().collect(Collectors.toSet());

        // Check if all topicIds have a corresponding TopicDto that meets the criteria
        return topicIdSet.stream().allMatch(topicId ->
            topicDtoList.stream()
                .anyMatch(dto ->
                    dto.getId().equals(topicId) &&
                    "sales and trading".equals(dto.getSource()) &&
                    "active".equals(dto.getStatus()) &&
                    "both".equals(dto.getVisibility())
                )
        );
    }
}
