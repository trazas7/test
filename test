<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>ScrAibe Add-in</title>
  <link rel="stylesheet" href="./taskpane.css" />
</head>
<body>
  <div class="container">
    <h1 class="header">ScrAibe</h1>
    <div class="button-group">
      <button id="btn-generate">GENERATE DRAFT</button>
      <button>EDIT & REPHRASE TEXT</button>
      <button>RUN COMPLIANCE CHECKS</button>
      <button>SUGGEST TITLE</button>
      <button>SUGGEST VISUAL</button>
      <button>GENERATE KEY MESSAGES</button>
      <button>TRANSLATE</button>
      <button>PUSH TO WORKFLOW</button>
      <button>RUN AD HOC TASK</button>
    </div>
  </div>

  <script src="./taskpane.js"></script>
</body>
</html>


body {
  font-family: Arial, sans-serif;
  margin: 0;
  padding: 20px;
  background: #f5f5f5;
}

.container {
  background: white;
  border-radius: 8px;
  padding: 20px;
  box-shadow: 0 0 8px rgba(0, 0, 0, 0.1);
}

.header {
  color: #2e5c4f;
  text-align: center;
  font-size: 24px;
  margin-bottom: 20px;
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

button {
  padding: 12px;
  font-size: 16px;
  border: none;
  background-color: #137547;
  color: white;
  border-radius: 5px;
  cursor: pointer;
  transition: background-color 0.2s ease-in-out;
}

button:hover {
  background-color: #0f5f3a;
}

