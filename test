import json
import os.path
from zipfile import ZipFile

import requests
from requests.auth import HTTPBasicAuth

headers = {}
client_id = 'WAfmUZHwqyvWSiJjQ5AVq14b4i2nBNDX'
client_secret = 'HimoDXpw5Oiqsrch'

def update_request_header_with_new_token():
    global headers
    headers_token = {"Content-Type": "application/x-www-form-urlencoded"}
    params = {"grant_type": "client_credentials"}

    token_response = requests.post('https://api-staging.staging.echonet/oauth2/v1/token',
                                   auth=HTTPBasicAuth(client_id, client_secret),
                                   headers=headers_token, params=params, verify=False)
    bearer_token = json.loads(token_response.content)["access_token"]
    headers = {"Authorization": f"Bearer {bearer_token}"}

# Function to process and download articles by IDs
def download_articles_by_ids(article_ids):
    for article_id in article_ids:
        status = True
        while status:
            response = requests.get(
                f"https://api-staging.staging.echonet/gm-gm-research-content-internet/v1/documents/{article_id}",
                headers=headers, verify=False)
            if response.status_code != 200:
                update_request_header_with_new_token()
            else:
                status = False
                # save zip
                with open(f"data/{article_id}.zip", mode="wb") as file:
                    file.write(response.content)
                # extract
                with ZipFile(f"data/{article_id}.zip", 'r') as zObject:
                    zObject.extractall(path="data")
                # rename files
                os.rename("data/rixml.xml", f"data/{article_id}_rixml.xml")
                if os.path.isfile("data/summary.html"):
                    os.rename("data/summary.html", f"data/{article_id}_summary.html")

