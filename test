<beans:beans xmlns="http://www.springframework.org/schema/security"
             xmlns:beans="http://www.springframework.org/schema/beans"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="
               http://www.springframework.org/schema/security
               http://www.springframework.org/schema/security/spring-security.xsd
               http://www.springframework.org/schema/beans
               http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- A single <http> block that covers all paths -->
    <http auto-config="false" create-session="never">
        <!-- Permit everything (SSO is external) -->
        <intercept-url pattern="/**" access="permitAll" />

        <!-- Disable typical Spring Security features -->
        <form-login disable="true"/>
        <http-basic entry-point-ref="forbiddenEntryPoint" />
        <anonymous enabled="false" />
        <headers disabled="true"/>

        <!-- Comment out or remove <csrf> for now -->
        <!-- <csrf/> -->
    </http>

    <!-- If anything tries to trigger an auth challenge, we just return 403. -->
    <beans:bean id="forbiddenEntryPoint"
        class="org.springframework.security.web.authentication.Http403ForbiddenEntryPoint"/>
</beans:beans>
