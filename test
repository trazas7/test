@Configuration
public class TempUserConfig {

    @Value("${custom-security.temp-user.username}")
    private String username;

    @Value("${custom-security.temp-user.password}")
    private String password;

    @Bean
    public UserDetailsService additionalUser(UserDetailsService baseService) {
        InMemoryUserDetailsManager manager;

        if (baseService instanceof InMemoryUserDetailsManager) {
            manager = (InMemoryUserDetailsManager) baseService;
        } else {
            manager = new InMemoryUserDetailsManager();
        }

        UserDetails tempUser = User.withUsername(username)
                .password("{noop}" + password)
                .roles("USER")
                .build();

        manager.createUser(tempUser);
        return manager;
    }
}
