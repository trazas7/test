def download_and_process_article(pub_id, headers):
    url = f"{base_url}/{pub_id}"
    response = requests.get(url, headers=headers, verify=False)

    if response.status_code == 200:
        # Ensure 'data' directory exists
        os.makedirs("data", exist_ok=True)
        print(f"Saving data in folder: {os.path.abspath('data')}")

        zip_path = f"data/{pub_id}.zip"
        with open(zip_path, "wb") as file:
            file.write(response.content)

        with ZipFile(zip_path, 'r') as zip_ref:
            zip_ref.extractall("data")

        # Rename files to include pub_id and add .pdf extension if no extension
        for file in os.listdir("data"):
            file_path = os.path.join("data", file)
            if file.endswith(".xml") and file != f"{pub_id}_rixml.xml":
                os.rename(file_path, os.path.join("data", f"{pub_id}_rixml.xml"))
            elif file.endswith(".html") and file != f"{pub_id}_summary.html":
                os.rename(file_path, os.path.join("data", f"{pub_id}_summary.html"))
            elif not os.path.splitext(file)[1]:  # If file has no extension
                os.rename(file_path, os.path.join("data", f"{file}.pdf"))

        # Remove all zip files in the data directory
        for file in os.listdir("data"):
            if file.endswith(".zip"):
                os.remove(os.path.join("data", file))

        print(f"Successfully processed article {pub_id}")
    else:
        print(f"Failed to download article {pub_id}. Status code: {response.status_code}")
