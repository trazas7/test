WITH publication_info AS (
    SELECT 
        ptav.attribute_value AS publication_type,
        COALESCE(lower(ph_language.tag_value), 'english') AS language,
        CASE 
            WHEN EXISTS (
                SELECT 1 
                FROM fidataadm.publication_has_tag_value ph_us_debt
                INNER JOIN fidataadm.tag_type tt_us_debt
                    ON tt_us_debt.id = ph_us_debt.tag_type_id
                WHERE ph_us_debt.publication_id = pub.id 
                AND tt_us_debt.name = 'US_Debt'
            ) THEN 'Y'
            ELSE 'N'
        END AS is_us_debt
    FROM 
        fidataadm.publication pub
    INNER JOIN fidataadm.publication_type pt 
        ON pub.publication_type_id = pt.id
    INNER JOIN fidataadm.publication_type_attribute pta 
        ON pta.publication_type_id = pt.id
    INNER JOIN fidataadm.pub_type_attribute_value ptav 
        ON ptav.id = pta.pubtype_attr_val_id
    LEFT JOIN fidataadm.publication_has_tag_value ph_language 
        ON ph_language.publication_id = pub.id
        INNER JOIN fidataadm.tag_type tt_language 
            ON tt_language.id = ph_language.tag_type_id 
            AND tt_language.column_name = 'bnpp_language'
    WHERE 
        pub.id = 'YOUR_PUBLICATION_ID'  -- Replace with specific publication_id
)
SELECT 
    rrp.page_code
FROM 
    publication_info
INNER JOIN fidataadm.rixml_receiver_page rrp 
    ON rrp.publication_type_category_id = (
        SELECT ptav.id
        FROM fidataadm.pub_type_attribute_value ptav
        WHERE ptav.attribute_value = publication_info.publication_type
    )
    AND rrp.language = publication_info.language
    AND rrp.is_for_us_debt = publication_info.is_us_debt
LIMIT 1;
