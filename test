        pub_ids_with_dates = [(pub_id, datetime.now().strftime("%d%m%y%H%M%S")) for pub_id in pub_ids] # You can replace with actual dates if available
        process_articles(pub_ids_with_dates, headers)
    elif choice == '2':
        input_data = input("Enter the publication IDs and dates (format: pub_id1:060824141939 pub_id2:060824141939): ").split()
        pub_ids_with_dates = [tuple(item.split(':')) for item in input_data]
        process_articles(pub_ids_with_dates, headers)
    else:
        print("Invalid choice")

if __name__ == "__main__":
    main()
