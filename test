def update_token():
    token_url = 'https://api-staging.staging.echonet/oauth2/v1/token'
    headers = {"Content-Type": "application/x-www-form-urlencoded"}
    params = {"grant_type": "client_credentials"}
    
    response = requests.post(token_url, auth=HTTPBasicAuth(client_id, client_secret), headers=headers, params=params, verify=False, proxies=proxies)
    
    if response.status_code == 200:
        return response.json()["access_token"]
    else:
        raise Exception("Failed to obtain token")

def search_articles(headers, days=2):
    end_date = datetime.now()
    start_date = end_date - timedelta(days=days)
    search_params = {
        "startDate": f"now-{days}d/d",
        "endDate": "now/d"
    }

    response = requests.post(search_url, json=search_params, headers=headers, verify=False, proxies=proxies)
    
    if response.status_code == 200:
        return [doc["researchId"] for doc in response.json().get("researchDocuments", [])]
    else:
        raise Exception(f"Search failed. Status code: {response.content}")

def ensure_unique_filename(directory, filename):
    base_name, extension = os.path.splitext(filename)
    counter = 1
    new_filename = filename
    while os.path.exists(os.path.join(directory, new_filename)):
        new_filename = f"{base_name}_{counter}{extension}"
        counter += 1
    return new_filename

def download_and_process_article(pub_id, pub_datetime, headers):
    url = f"{base_url}/{pub_id}"
    response = requests.get(url, headers=headers, verify=False, proxies=proxies)

    if response.status_code == 200:
        # Ensure 'data' directory exists
        os.makedirs('data', exist_ok=True)
        print(f"Saving data in folder: 'data'")

        zip_path = f"data/{pub_id}.zip"
        with open(zip_path, "wb") as file:
            file.write(response.content)

        with ZipFile(zip_path, mode="r") as zip_ref:
            extracted_files = zip_ref.namelist()  # List of files that will be extracted
            zip_ref.extractall("data")

        # Process each extracted file
        for extracted_file in extracted_files:
            extracted_file_path = os.path.join('data', extracted_file)
            if os.path.exists(extracted_file_path):
                # Check if the file is rixml.xml or the other file
                if 'rixml.xml' in extracted_file:
                    new_rixml_filename = ensure_unique_filename('data', f"{pub_id}_{pub_datetime}.xml")
                    os.rename(extracted_file_path, os.path.join('data', new_rixml_filename))
                    print(f"Renamed rixml.xml to {new_rixml_filename}")
                else:
                    # Rename the other file to publication_id_datetime.pdf
                    new_pdf_filename = ensure_unique_filename('data', f"{pub_id}_{pub_datetime}.pdf")
                    os.rename(extracted_file_path, os.path.join('data', new_pdf_filename))
                    print(f"Renamed {extracted_file} to {new_pdf_filename}")

        # Remove the zip file after extraction
        os.remove(zip_path)

    else:
        print(f"Failed to download and process article {pub_id}. Status code: {response.content}")

def process_articles(pub_ids_with_dates, headers):
    for pub_id, pub_datetime in pub_ids_with_dates:
        try:
            download_and_process_article(pub_id, pub_datetime, headers)
        except Exception as e:
            print(f"Error processing article {pub_id}: {str(e)}")
            if "token" in str(e).lower():
                token = update_token()
                headers = {"Authorization": f"Bearer {token}"}
                try:
                    download_and_process_article(pub_id, pub_datetime, headers)
                except Exception as e:
                    print(f"Failed to process article {pub_id} after token refresh: {str(e)}")

def main():
    token = update_token()
    headers = {"Authorization": f"Bearer {token}"}

    choice = input("Enter '1' to search and download, or '2' to provide a list of IDs with dates: ")

    if choice == '1':
