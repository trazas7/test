SELECT DISTINCT pub.*
FROM fidataadm.publication pub
    -- tag: Suitable_for_Corporates
    JOIN fidataadm.publication_has_tag_value phtv1
        ON phtv1.publication_id = pub.id
    JOIN fidataadm.tag_type tt1
        ON phtv1.tag_type_id = tt1.id

    -- tag: asset class = Commodities
    JOIN fidataadm.publication_has_tag_value phtv2
        ON phtv2.publication_id = pub.id
    JOIN fidataadm.tag_type tt2
        ON phtv2.tag_type_id = tt2.id
WHERE pub.status = 3
  AND pub.publish_date BETWEEN DATE '2025-01-01' AND DATE '2025-08-31'
  AND tt1.name = 'Suitable_for_Corporates'
  AND tt2.column_name = 'bnpp_asset_class'
  AND phtv2.tag_value = 'Commodities';