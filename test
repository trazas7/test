} else if (Office.context.host === Office.HostType.PowerPoint) {
  await PowerPoint.run(async (context) => {
    if (task.shouldSelectText) {
      // 1) User wants only the current selection
      const selection = context.presentation.getSelectedTextRange();
      selection.load("text");
      await context.sync();
      selectedText = selection.text.trim();
    } else {
      // 2) User wants the entire slide deck
      const slides = context.presentation.slides;
      slides.load("items");
      await context.sync();

      let fullText = "";
      for (const slide of slides.items) {
        // load all shapes on this slide
        const shapes = slide.shapes;
        shapes.load("items");
        await context.sync();

        // queue up loading each shape's text
        for (const shape of shapes.items) {
          if (shape.textFrame) {
            shape.textFrame.load("text");
          }
        }
        await context.sync();

        // read out the text
        for (const shape of shapes.items) {
          const tf = shape.textFrame;
          if (tf && tf.text) {
            fullText += tf.text + "\n";
          }
        }
      }

      selectedText = fullText.trim();
    }
  });
}
