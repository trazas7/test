// Declare the config object (initially empty)
export const TASK_CONFIG: Record<string, any> = {};

// Load and populate it before using
export async function initializeTaskConfig(): Promise<void> {
  const prompts = await getLLMPrompts();

  prompts.forEach(prompt => {
    const key = `${prompt.name.toLowerCase()}-btn`;

    TASK_CONFIG[key] = {
      heading: prompt.name,
      prompt: prompt.prompt,
      name: prompt.name
    };
  });
}