WITH publication_info AS (
    SELECT 
        pub.id AS publication_id,
        ptav.attribute_value AS publication_type,
        COALESCE(lower(ph_language.tag_value), 'english') AS language,
        CASE 
            WHEN ph_us_debt.tag_value = 'US Debt' THEN 'US Debt'
            ELSE 'N'
        END AS us_debt_status
    FROM 
        fidataadm.publication pub
    INNER JOIN fidataadm.publication_type pt 
        ON pt.id = pub.publication_type_id
    INNER JOIN fidataadm.pub_type_attribute_value ptav 
        ON ptav.id = pt.publication_type_id  -- Determines if it's Credit or Market360
    LEFT JOIN fidataadm.publication_has_tag_value ph_language 
        ON ph_language.publication_id = pub.id
        INNER JOIN fidataadm.tag_type tt_language 
            ON tt_language.id = ph_language.tag_type_id 
            AND tt_language.column_name = 'bnpp_language'
    LEFT JOIN fidataadm.publication_has_tag_value ph_us_debt 
        ON ph_us_debt.publication_id = pub.id
        INNER JOIN fidataadm.tag_type tt_us_debt 
            ON tt_us_debt.id = ph_us_debt.tag_type_id 
            AND tt_us_debt.name = 'US_Debt'
    WHERE 
        pub.id = 'YOUR_PUBLICATION_ID'  -- Replace with specific publication_id
)
SELECT 
    rrp.page_code,
    CASE 
        WHEN publication_type = 'Market360' AND us_debt_status = 'N' THEN
            CASE 
                WHEN language = 'english' THEN 1
                WHEN language = 'chinese' THEN 2
                WHEN language = 'japanese' THEN 3
                WHEN language = 'french' THEN 12
                ELSE NULL
            END
        WHEN publication_type = 'Credit' AND us_debt_status = 'US Debt' THEN
            CASE 
                WHEN language = 'english' THEN 4
                ELSE NULL
            END
        WHEN publication_type = 'Credit' AND us_debt_status = 'N' THEN
            CASE 
                WHEN language = 'french' THEN 13
                ELSE NULL
            END
        ELSE NULL
    END AS bbg_class
FROM 
    publication_info
INNER JOIN fidataadm.rixml_receiver_page rrp 
    ON rrp.publication_type_category_id = (
        SELECT id FROM fidataadm.pub_type_attribute_value 
        WHERE attribute_value = publication_info.publication_type
    );
