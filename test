getElementById("insert-result").addEventListener("click", async () => {
  const outputDiv = getElementById("output-text");
  let textToInsert = "";

  const selection = window.getSelection();
  if (selection && selection.toString().trim()) {
    textToInsert = selection.toString();
  } else {
    textToInsert = outputDiv.innerText;
  }

  if (!textToInsert.trim()) {
    showMessage("No text to insert.", "error");
    return;
  }

  try {
    if (Office.context.host === Office.HostType.Word) {
      await Word.run(async (context) => {
        const range = context.document.getSelection();
        range.insertText(textToInsert, Word.InsertLocation.replace);
        await context.sync();
      });
    } else if (Office.context.host === Office.HostType.PowerPoint) {
      await PowerPoint.run(async (context) => {
        const selectedTextRange = context.presentation.getSelectedTextRange();
        selectedTextRange.load("text");
        await context.sync();

        if (!selectedTextRange.text.trim()) {
          showMessage("No text selected in PowerPoint.", "error");
          return;
        }

        // Replace selected text
        selectedTextRange.text = textToInsert;
        await context.sync();
      });
    }
  } catch (error) {
    console.error(error);
    showMessage("Error inserting text.", "error");
  }
});

<Requirements>
  <Sets DefaultMinVersion="1.5">
    <Set Name="PowerPointApi" />
  </Sets>
</Requirements>
