<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Disclaimer Page</title>
    <style>
        /* Page Styling */
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            margin: 20px;
        }

        /* Disclaimer Container */
        #disclaimerContainer {
            display: block;
            width: 80%;
            height: 400px;
            border: 1px solid black;
            box-shadow: 0px 0px 10px gray;
            margin: 20px auto;
        }

        /* Close Button */
        .btn {
            padding: 10px 20px;
            margin-top: 10px;
            border: none;
            cursor: pointer;
            font-size: 16px;
            background: #007bff;
            color: white;
        }
    </style>
</head>
<body>

    <h1>Welcome to Our Website</h1>
    <p>You must read and accept the disclaimer before proceeding.</p>

    <!-- Embedded Disclaimer -->
    <iframe id="disclaimerContainer" src="disclaimer.html"></iframe>

    <!-- Close Button -->
    <button class="btn" onclick="closeDisclaimer()">Close</button>

    <script>
        function closeDisclaimer() {
            document.getElementById("disclaimerContainer").style.display = "none";
        }
    </script>

</body>
</html>
