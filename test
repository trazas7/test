WITH publication_info AS (
    SELECT 
        rrp.page_code,
        ptav.attribute_value AS publication_type,
        COALESCE(lower(rrp.publication_language), 'english') AS language,
        CASE 
            WHEN us_debt_tag.tag_value = 'US Debt' THEN 'US Debt'
            ELSE 'N'
        END AS us_debt_status
    FROM 
        fidataadm.rixml_receiver_page rrp
    INNER JOIN fidataadm.publication pub 
        ON pub.id = rrp.publication_id
    INNER JOIN fidataadm.publication_type pt 
        ON pt.id = pub.publication_type_id
    INNER JOIN fidataadm.pub_type_attribute_value ptav 
        ON ptav.id = pt.publication_type_id -- Joining to determine if it's Credit or Market360
    LEFT JOIN fidataadm.publication_has_tag_value us_debt_tag 
        ON us_debt_tag.publication_id = pub.id
        INNER JOIN fidataadm.tag_type tt_us_debt 
            ON tt_us_debt.id = us_debt_tag.tag_type_id 
            AND tt_us_debt.name = 'US_Debt'
    WHERE 
        pub.id = 'YOUR_PUBLICATION_ID'  -- Replace with the specific publication_id
)
SELECT 
    page_code,
    CASE 
        WHEN publication_type = 'Market360' AND us_debt_status = 'N' THEN
            CASE 
                WHEN language = 'english' THEN 1
                WHEN language = 'chinese' THEN 2
                WHEN language = 'japanese' THEN 3
                WHEN language = 'french' THEN 12
                ELSE NULL
            END
        WHEN publication_type = 'Credit' AND us_debt_status = 'US Debt' THEN
            CASE 
                WHEN language = 'english' THEN 4
                ELSE NULL
            END
        WHEN publication_type = 'Credit' AND us_debt_status = 'N' THEN
            CASE 
                WHEN language = 'french' THEN 13
                ELSE NULL
            END
        ELSE NULL
    END AS bbg_class
FROM 
    publication_info;
