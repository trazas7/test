
function renderUI(authenticated: boolean) {
  const app = document.getElementById("app");
  if (!app) return;

  if (authenticated) {
    app.innerHTML = `
      <h2>Welcome!</h2>
      <p>You are signed in via SSO.</p>
    `;
  } else {
    app.innerHTML = `
      <button id="ssoLoginBtn">Login with SSO</button>
    `;
    document.getElementById("ssoLoginBtn")?.addEventListener("click", openSSOLogin);
  }
}

function openSSOLogin() {
  const ssoUrl = "https://markets360-stg.dev.bnpparibas.com"; // SSO-protected site
  const popup = window.open(ssoUrl, "_blank", "width=600,height=700");

  if (!popup) {
    console.error("Popup blocked or failed");
    return;
  }

  const checkInterval = setInterval(() => {
    if (popup.closed) {
      clearInterval(checkInterval);
      console.log("Popup closed — assuming login completed");
      renderUI(true);
    }
  }, 500);
}

Office.initialize = () => {
  Office.onReady().then(() => {
    console.log("Office is ready");
    renderUI(false); // Start with unauthenticated UI
  });
};
