import DOMPurify from 'dompurify';

export function minimalize(html: string) {
  // convert block endings to <br>, then keep only <a href> and <br>
  const withBreaks = html.replace(/<\/(p|div|li|tr|h[1-6])>/gi, '<br>');
  return DOMPurify.sanitize(withBreaks, {
    ALLOWED_TAGS: ['a', 'br'],
    ALLOWED_ATTR: ['href'],
    KEEP_CONTENT: true
  }).replace(/(?:<br>\s*){3,}/g, '<br><br>').trim();
}