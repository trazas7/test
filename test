<!-- show ALL sub-tags for this asset class header, but highlight only selected ones -->
<div class="right-panel"
     *ngIf="selectedThemes[header.key]?.size > 0 && selectedHeader != header">
  <div class="button-container"
       *ngFor="let sub of toArray(getSubTheme(header.key))">
    <button class="box-right selSubTheme"
            [ngClass]="{ 'selected': selectedThemes[header.key]?.has(sub) }"
            (click)="onThemesValueClick(sub, header.key, 'Asset Class')">
      {{ sub }}
    </button>
  </div>
</div>