
import createDOMPurify from 'dompurify';
const DOMPurify = createDOMPurify(window);

/**
 * Keep only anchors (<a href="...">...</a>) and make everything else plain text.
 * Block ends become <br> so you don't lose line breaks.
 */
export function keepLinksOnly(html: string): string {
  // 1) turn common block endings into <br> (optional bullet for <li>)
  const withBreaks = html
    .replace(/<\/(p|div|li|tr|h[1-6])>/gi, '<br>')
    .replace(/<li[^>]*>/gi, '• ');

  // 2) strip everything except <a href> (+ <br> if you want line breaks)
  const minimal = DOMPurify.sanitize(withBreaks, {
    ALLOWED_TAGS: ['a', 'br'],     // use ['a'] if you don't want <br>
    ALLOWED_ATTR: ['href'],
    KEEP_CONTENT: true
  });

  // 3) tidy whitespace
  return minimal
    .replace(/\s*&nbsp;\s*/gi, ' ')
    .replace(/(?:<br>\s*){3,}/g, '<br><br>')
    .trim();
}