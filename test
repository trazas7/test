startResize(event: MouseEvent | TouchEvent) {
  event.preventDefault();
  this.dragging = true;
  
  // Use requestAnimationFrame for smooth updates
  const handleMove = (e: MouseEvent | TouchEvent) => {
    if (!this.dragging) return;
    
    requestAnimationFrame(() => {
      this.handleResize(e);
    });
  };
  
  const handleEnd = () => {
    this.dragging = false;
    document.removeEventListener('mousemove', handleMove);
    document.removeEventListener('mouseup', handleEnd);
    document.removeEventListener('touchmove', handleMove);
    document.removeEventListener('touchend', handleEnd);
  };
  
  document.addEventListener('mousemove', handleMove);
  document.addEventListener('mouseup', handleEnd);
  document.addEventListener('touchmove', handleMove);
  document.addEventListener('touchend', handleEnd);
}

handleResize(event: MouseEvent | TouchEvent) {
  if (!this.dragging) return;
  
  const clientX = event instanceof MouseEvent ? event.clientX : event.touches[0].clientX;
  const screenWidth = window.innerWidth;
  
  let leftPercent = (clientX / screenWidth) * 100;
  let rightPercent = 100 - leftPercent;
  
  // Constrain percentages with min/max bounds
  const minPercent = 20;
  const maxPercent = 80;
  
  leftPercent = Math.max(minPercent, Math.min(leftPercent, maxPercent));
  rightPercent = 100 - leftPercent;
  
  // Use CSS custom properties for smoother updates
  this.leftWidth = leftPercent;
  this.rightWidth = rightPercent;
}


.left-pane, .right-pane {
  transition: none; /* Remove transitions during drag */
  will-change: width; /* Hint to browser for optimization */
}

.drag-handle {
  cursor: ew-resize;
  user-select: none;
  touch-action: none; /* Prevent scrolling on touch devices */
}

/* Add active state */
.drag-handle.active {
  background: rgba(0, 0, 0, 0.1);
}


<div class="drag-handle" 
     [class.active]="dragging"
     (mousedown)="startResize($event)"
     (touchstart)="startResize($event)">
  <img src="assets/icons/chat_drag.svg" class="drag-icon">
</div>
