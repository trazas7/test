if (Office.context.host === Office.HostType.Word) {
  await Word.run(async (context) => {
    // 1) Try the current selection
    const selection = context.document.getSelection();
    selection.load("text");
    await context.sync();
    const selText = selection.text.trim();

    if (selText) {
      // Use what’s selected
      selectedText = selText;
    }
    else if (task.shouldSelectText) {
      // Nothing selected + allowed to grab whole doc → get body
      const body = context.document.body;
      body.load("text");
      await context.sync();
      selectedText = body.text.trim();
    }
    // else leave selectedText="" so your existing error check fires
  });
}
